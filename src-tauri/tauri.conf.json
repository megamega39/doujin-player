{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "同人音声プレイヤー",
  "version": "0.3.1",
  "identifier": "com.doujin-player.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "同人音声プレイヤー",
        "width": 1280,
        "height": 800,
        "minWidth": 480,
        "minHeight": 400,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5QTAzNjVGMjI5QjQ0NDkKUldSSlJKc2lYemFnNlpjUUtzZVBKRXJZazdvNkY3K2xuNGhqejFKeG55YUpyam5mNUxlN210SHEK",
      "endpoints": [
        "https://github.com/megamega39/doujin-player/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
